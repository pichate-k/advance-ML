# Training pipeline 
import numpy as np
import pandas as pd
import pickle
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error

# Function Open Data
def load_train_data(file_path):
    df = pd.read_csv(file_path)
    X = df.drop('Price', axis=1)
    y = df['Price']
    return X, y

# Function Data Prep & Cleansing
# calculate mean and fill to NaN
def fit_and_clean_data(X_train):
    # หาค่าเฉลี่ย (Mean) จาก Train และเก็บค่าไว้เป็นพจนานุกรม (Dictionary)
    pipeline_means = X_train.mean().to_dict()
    # เติมค่าสูญหายด้วยค่าเฉลี่ยที่หาได้
    X_cleaned = X_train.fillna(pipeline_means)
    return X_cleaned, pipeline_means

# Function Transform data
# หาค่าเฉลี่ยและ SD ของการทำ Scaling และจัดการแปลงเป็น Z-Score
def fit_and_transform_data(X_cleaned):
    # หาค่า Mean และ Standard Deviation เพื่อใช้ทำ Feature Scaling
    pipeline_scaler_mean = X_cleaned.mean().to_dict()
    pipeline_scaler_std = X_cleaned.std().to_dict()
    
    # แปลงข้อมูล (Z-score Scaling)
    X_transformed = (X_cleaned - pd.Series(pipeline_scaler_mean)) / pd.Series(pipeline_scaler_std)
    return X_transformed, pipeline_scaler_mean, pipeline_scaler_std

# Function Train Model
def train_model(X_transformed, y_train):
    model = LinearRegression()
    model.fit(X_transformed, y_train)
    return model

# Function Evaluate
def evaluate_train(y_true, y_pred):
    rmse = np.sqrt(mean_squared_error(y_true, y_pred))
    print(f"--- [Train Evaluation] RMSE: {rmse:,.2f} บาท ---")

# Function Save Model & Pipeline Metrics
def save_pipeline_artifacts(model, pipeline_means, scaler_mean, scaler_std, filepath="house_pipeline.pkl"):
    # มัดรวมโมเดลและค่าสถิติที่จำเป็นต้องใช้ตอนแปลงข้อมูลฝั่ง Test ไว้ในไฟล์เดียวกัน
    pipeline_artifacts = {
        'model': model,
        'imputer_means': pipeline_means,
        'scaler_mean': scaler_mean,
        'scaler_std': scaler_std
    }
    with open(filepath, 'wb') as f:
        pickle.dump(pipeline_artifacts, f)
    print(f"บันทึกโมเดลและโครงสร้าง Pipeline สำเร็จที่ไฟล์: {filepath}")

#----- Main Program - Train -----
print("=== เริ่มต้นการ Training ===")
X_train_raw, y_train_raw = load_train_data("Place your training data file path")

X_train_clean, imputer_means = fit_and_clean_data(X_train_raw)
X_train_transformed, scaler_mean, scaler_std = fit_and_transform_data(X_train_clean)
trained_model = train_model(X_train_transformed, y_train_raw)

# Evaluation Train process
y_train_pred = trained_model.predict(X_train_transformed)
evaluate_train(y_train_raw, y_train_pred)

# save model 
save_pipeline_artifacts(trained_model, imputer_means, scaler_mean, scaler_std)
